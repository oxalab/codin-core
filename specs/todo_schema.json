{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Todo list schema",
  "type": "object",
  "properties": {
    "todos": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "content": {"type": "string"},
          "status": {"type": "string", "enum": ["pending","in_progress","done"]},
          "assignee": {"type": "string"}
        },
        "required": ["id","content","status"]
      }
    }
  },
  "additionalProperties": false
}
